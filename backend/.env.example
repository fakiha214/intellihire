# Backend Environment Variables
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=sqlite:///intellihire.db

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# OpenRouter API (for AI Chatbot - Get free key from https://openrouter.ai/)
OPENROUTER_API_KEY=sk_live_your_api_key_here

# Chat Configuration
CHAT_RATE_LIMIT=5
CHAT_CONTEXT_WINDOW=10

# Stripe (TEST MODE) - get test keys at https://dashboard.stripe.com/test/apikeys
# Keys must start with sk_test_ / pk_test_. Test card: 4242 4242 4242 4242.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
EVENT_CREATION_FEE_CENTS=4900
PAYMENT_CURRENCY=usd

# Optional: Email Configuration (for future use)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
